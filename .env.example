# NexusAgent AI - Environment Configuration (PLACEHOLDERS ONLY)
# Copy to .env and replace every placeholder with a real secret before running.
# docker-compose.yml reads this file for values; variables fall back to safe
# LOCAL defaults when omitted (see docker-compose.yml).

# ----------------------------------------------------------------- Postgres
# Used by the `db` service and to build the backend DATABASE_URL in compose.
POSTGRES_USER=nexusagent
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=nexusagent

# ------------------------------------------------------------------- App
APP_NAME=NexusAgent AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# --------------------------------------------------------- Database (backend)
# NOTE: In docker-compose.yml this is OVERRIDDEN to point at the `db` service
# (postgresql+psycopg2://nexusagent:***@db:5432/nexusagent). This localhost
# value is the default used when running the backend outside compose.
DATABASE_URL=postgresql+asyncpg://nexusagent:replace-with-a-strong-db-password@localhost:5432/nexusagent

# ------------------------------------------------------------------ Redis
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------------- JWT
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------ LLM Providers
# Never commit real keys. Leave blank to use the offline/local fallbacks.
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --------------------------------------------------- Embeddings & RAG answer
EMBEDDINGS_PROVIDER=local
RAG_LLM_PROVIDER=local
RAG_LLM_MODEL=openai/gpt-4o-mini

# -------------------------------------------------------------------- CORS
# Comma-separated origins the browser loads the UI from (no spaces).
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000

# ------------------------------------------------------------ Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# ------------------------------------------------------------ File Upload
MAX_UPLOAD_SIZE_MB=50

# ----------------------------------------------------------- Cost Tracking
ENABLE_COST_TRACKING=true

# ---------------------------------------------------------------- Security
# Generate with: openssl rand -hex 16
SECURITY_PASSWORD_SALT=replace-with-a-random-salt
SECURITY_FORCE_DEV_MODE=false

# ------------------------------------------------------------ Feature Flags
ENABLE_WEBHOOK_TOOL=true
ENABLE_LEAD_CAPTURE_TOOL=true
ENABLE_HUMAN_ESCALATION_TOOL=true

# ---------------------------------------------- Tool Execution Engine bounds
TOOL_EXECUTION_TIMEOUT_SECONDS=15.0
TOOL_EXECUTION_MAX_OUTPUT_CHARS=10000

# ------------------------------------------------------------------ Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --------------------------------------------------------- Frontend (build)
# Inlined into the client bundle at build time. The browser calls the backend
# directly, so this is the origin the UI is served from.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
