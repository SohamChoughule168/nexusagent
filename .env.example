# NexusAgent AI - Environment Configuration (PLACEHOLDERS ONLY)
# Copy to .env and replace every placeholder with a real secret before running.

# Application
APP_NAME=NexusAgent AI
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/nexusagent

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT secrets (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Providers (never commit real keys)
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Security
SECURITY_PASSWORD_SALT=replace-with-a-random-salt

# CORS (comma-separated origins in real deployment)
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
