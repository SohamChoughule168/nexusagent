# NexusAgent AI - Backend environment (PLACEHOLDERS ONLY)
#
# Convenience copy of the backend-relevant variables for running the FastAPI
# service OUTSIDE Docker (e.g. `uvicorn app.main:app --reload` after
# `pip install -e .`). In the containerised stack, docker-compose.yml passes
# these values explicitly via its `environment:` block and the backend reads
# the repo-root .env (see backend/app/core/config.py -> ENV_FILE), so this file
# is not used by Compose. Keep it in sync with .env.example / env.production.example.
#
# All secrets below are placeholders — replace before use. Never commit real values.

# ------------------------------------------------------------------- App
APP_NAME=NexusAgent AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
# Optional on-disk log sinks (leave blank to log to stdout only, container-friendly).
# When set, logs also write to a size-capped rotating file (LOG_MAX_BYTES / LOG_BACKUP_COUNT).
LOG_FILE=
ACCESS_LOG_FILE=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
# Emit one structured access-log line per HTTP request.
LOG_ACCESS_ENABLED=true

# ---- Observability ----
# Namespace prefix for Prometheus metrics (nexusagent_http_*).
PROMETHEUS_NAMESPACE=nexusagent
# Master switch for the /metrics endpoint + HTTP metrics middleware.
METRICS_ENABLED=true

# --------------------------------------------------------- Database (backend)
# Synchronous psycopg2 dialect (asyncpg is NOT a dependency).
DATABASE_URL=postgresql+psycopg2://nexusagent:replace-with-a-strong-db-password@localhost:5432/nexusagent
# Connection-pool sizing (applies when DEBUG=false; DEBUG uses NullPool).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ------------------------------------------------------------------ Redis
REDIS_URL=redis://localhost:6379/0

# ---- Trusted reverse proxy ----
# Enable ONLY when nginx (or another edge) is the sole public entrypoint and
# the backend port is NOT exposed. Honours X-Forwarded-* for client IP / url_for.
TRUST_PROXY=false

# -------------------------------------------------------------------- JWT
# Generate each with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------ LLM Providers
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --------------------------------------------------- Embeddings & RAG answer
EMBEDDINGS_PROVIDER=local
RAG_LLM_PROVIDER=local
RAG_LLM_MODEL=openai/gpt-4o-mini

# -------------------------------------------------------------------- CORS
# Comma-separated origins the browser loads the UI from (no spaces).
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost,http://127.0.0.1:3000

# ------------------------------------------------------------ Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# ------------------------------------------------------------ File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,csv,html,md,json
ALLOWED_MIME_TYPES=application/pdf
# Local directory where uploaded raw bytes are persisted (created on demand).
UPLOAD_STORAGE_DIR=./storage/uploads

# ----------------------------------------------------------- Cost Tracking
ENABLE_COST_TRACKING=true

# ---------------------------------------------------------------- Security
# Generate with: openssl rand -hex 16
SECURITY_PASSWORD_SALT=replace-with-a-random-salt
SECURITY_FORCE_DEV_MODE=false

# ------------------------------------------------------------ Feature Flags
ENABLE_WEBHOOK_TOOL=true
ENABLE_LEAD_CAPTURE_TOOL=true
ENABLE_HUMAN_ESCALATION_TOOL=true

# ---------------------------------------------- Tool Execution Engine bounds
TOOL_EXECUTION_TIMEOUT_SECONDS=15.0
TOOL_EXECUTION_MAX_OUTPUT_CHARS=10000

# ----------------------------------------------------------- Readiness gating
# Make Redis a HARD dependency of /ready (503 when down). Default false: the
# app degrades gracefully without Redis (DB + storage stay required).
HEALTH_REQUIRE_REDIS=false

# --------------------------------------------------------- Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --------------------------------------------------------- Build metadata
# Injected at image build time (Dockerfile BUILD_GIT_SHA / BUILD_TIMESTAMP).
# Leave blank for local/dev; surfaced by GET /version.
BUILD_GIT_SHA=
BUILD_TIMESTAMP=
