# NexusAgent AI - AWS PRODUCTION environment template (PLACEHOLDERS ONLY)
#
# Copy this file to `.env.production` (gitignored) and replace every
# `replace-with-*` value with a real secret before deploying:
#
#     cp env.production.example .env.production
#     vi .env.production
#
# docker-compose.aws.yml reads this file via `--env-file .env.production`.
# Required secrets (JWT_*, SECURITY_PASSWORD_SALT, POSTGRES_PASSWORD) have NO
# defaults in the compose file on purpose - deployment fails fast if omitted.
#
# Never commit the real `.env.production`. For higher assurance, store these
# values in AWS Secrets Manager and export them into the env at deploy time
# (see docs/deployment/aws-secrets.md).

# --------------------------------------------------------------- AWS endpoints
# From your RDS instance (the endpoint hostname, not the full URL).
RDS_ENDPOINT=replace-with-your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
# From your ElastiCache (Redis) replication group / node endpoint.
# If you run redis as a container on the host instead, set this to `redis` and
# uncomment the redis service in docs/deployment/aws.md > "Redis options".
ELASTICACHE_ENDPOINT=replace-with-your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379

# ----------------------------------------------------- Domain / TLS (HTTPS)
# The public domain the app is served from, e.g. nexusagent.example.com.
# Required for Let's Encrypt certificate issuance (see docs/deployment/tls.md).
DOMAIN=replace-with-your-domain.example.com
# Contact email for the Let's Encrypt account / expiry notices.
LETSENCRYPT_EMAIL=ops@replace-with-your-domain.example.com
# Host path certbot writes the ACME HTTP-01 challenge into (nginx serves it).
CERTBOT_WEBROOT=/var/www/letsencrypt
# Active nginx config. Leave as the HTTP config for the initial deploy; once
# init-letsencrypt.sh issues a certificate it flips this to ./nginx/tls.conf.
NGINX_CONF=./nginx/nginx.conf

# ----------------------------------------------------------------- Postgres (RDS)
# The DB name/user you created on the RDS instance. The password is a REAL
# secret - generate with: openssl rand -base64 24
POSTGRES_USER=nexusagent
POSTGRES_PASSWORD=replace-with-a-strong-rds-db-password
POSTGRES_DB=nexusagent
# Connection-pool sizing (applies when DEBUG=false; DEBUG uses NullPool).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ------------------------------------------------------------------- App
APP_NAME=NexusAgent AI
APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_FORMAT=json
# Optional on-disk log sinks (blank = stdout only, container-friendly).
LOG_FILE=
ACCESS_LOG_FILE=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_ACCESS_ENABLED=true
# Prometheus metrics master switch (/metrics endpoint + HTTP metrics middleware).
METRICS_ENABLED=true
PROMETHEUS_NAMESPACE=nexusagent
# Trusted reverse proxy: docker-compose.aws.yml sets TRUST_PROXY=true because
# nginx is the sole public entrypoint (backend publishes no host port). Leave
# false if you ever expose the backend port directly.
TRUST_PROXY=false

# ------------------------------------------------------------ LLM Providers
# Never commit real keys. Leave blank to use the offline/local fallbacks.
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --------------------------------------------------- Embeddings & RAG answer
EMBEDDINGS_PROVIDER=local
RAG_LLM_PROVIDER=local
RAG_LLM_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------- JWT secrets
# Generate each with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------------------------- CORS
# The production origin(s) the browser loads the UI from (comma-separated, no
# spaces). Set to your real domain, e.g. https://nexusagent.example.com
BACKEND_CORS_ORIGINS=https://replace-with-your-domain.example.com

# ------------------------------------------------------------ Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# ------------------------------------------------------------ File Upload
# Must match nginx client_max_body_size. Uploads are stored on the EBS volume
# at /data/nexusagent/uploads (set inside docker-compose.aws.yml), so this only
# bounds request size here.
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,csv,html,md,json
ALLOWED_MIME_TYPES=application/pdf

# ----------------------------------------------------------- Cost Tracking
ENABLE_COST_TRACKING=true

# ---------------------------------------------------------------- Security
# Generate with: openssl rand -hex 16
SECURITY_PASSWORD_SALT=replace-with-a-random-salt
SECURITY_FORCE_DEV_MODE=false

# ------------------------------------------------------------ Feature Flags
ENABLE_WEBHOOK_TOOL=true
ENABLE_LEAD_CAPTURE_TOOL=true
ENABLE_HUMAN_ESCALATION_TOOL=true

# ---------------------------------------------- Tool Execution Engine bounds
TOOL_EXECUTION_TIMEOUT_SECONDS=15.0
TOOL_EXECUTION_MAX_OUTPUT_CHARS=10000

# --------------------------------------------------------- Frontend (build)
# Public origin the UI is served from. The browser calls the backend through
# nginx on this SAME origin (API is under /api). Use https in production.
NEXT_PUBLIC_API_BASE_URL=https://replace-with-your-domain.example.com/api/v1

# --------------------------------------------------- AWS Secrets Manager
# Optional hardening (docs/deployment/aws-secrets.md). If set, run
# `deploy/fetch-secrets.sh` to render .env.production from a JSON secret
# instead of editing it by hand. Leave blank to use a local .env.production.
AWS_REGION=us-east-1
AWS_SECRETS_MANAGER_SECRET_NAME=

# ----------------------------------------------------------- Readiness gating
# Make Redis a HARD dependency of /ready (503 when down). Default false: the
# app degrades gracefully without Redis (DB + storage remain required).
HEALTH_REQUIRE_REDIS=false

# --------------------------------------------------------- Build metadata
# Injected at image build time (Dockerfile BUILD_GIT_SHA / BUILD_TIMESTAMP).
# Leave blank for local/dev; surfaced by GET /version.
BUILD_GIT_SHA=
BUILD_TIMESTAMP=
