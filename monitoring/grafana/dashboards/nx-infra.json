      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 4,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(node_cpu_seconds_total[5m])",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
