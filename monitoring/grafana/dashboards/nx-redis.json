          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
