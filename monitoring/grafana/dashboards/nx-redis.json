{
  "id": null,
  "uid": "nx-redis",
  "title": "NexusAgent · Redis",
  "description": "Redis connectivity, memory, cache hit rate and key lifecycle.",
  "tags": [
    "nexusagent",
    "observability",
    "redis"
  ],
  "editable": true,
  "grafana_net": false,
  "schemaVersion": 39,
  "version": 1,
  "timezone": "",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "--grafana--",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Redis up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 0.999
              },
              {
                "color": "red",
                "value": 1.0001
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "name": "Value"
            },
            "properties": [
              {
                "id": "thresholdsStyle",
                "value": {
                  "mode": "background"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "nexusagent_redis_up",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connected clients",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexusagent_redis_connected_clients",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache hit rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 80
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 40
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "name": "Value"
            },
            "properties": [
              {
                "id": "thresholdsStyle",
                "value": {
                  "mode": "background"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "(nexusagent_redis_keyspace_hits / clamp_min(nexusagent_redis_keyspace_hits + nexusagent_redis_keyspace_misses, 1)) * 100",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime (s)",
