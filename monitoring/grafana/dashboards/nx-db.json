{
  "id": null,
  "uid": "nx-db",
  "title": "NexusAgent · Database",
  "description": "PostgreSQL health, connection pool and application state.",
  "tags": [
    "nexusagent",
    "observability",
    "db"
  ],
  "editable": true,
  "grafana_net": false,
  "schemaVersion": 39,
  "version": 1,
  "timezone": "",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "--grafana--",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Database up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 0.999
              },
              {
                "color": "red",
                "value": 1.0001
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "name": "Value"
            },
            "properties": [
              {
                "id": "thresholdsStyle",
                "value": {
                  "mode": "background"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "nexusagent_db_up",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pool utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 70
              },
              {
                "color": "yellow",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "name": "Value"
            },
            "properties": [
              {
                "id": "thresholdsStyle",
                "value": {
                  "mode": "background"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "(nexusagent_db_connections_in_use / clamp_min(nexusagent_db_connection_pool_size, 1)) * 100",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
