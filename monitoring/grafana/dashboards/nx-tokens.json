{
  "id": null,
  "uid": "nx-tokens",
  "title": "NexusAgent · Token Usage",
  "description": "LLM token and cost consumption (cumulative and rate).",
  "tags": [
    "nexusagent",
    "observability",
    "tokens"
  ],
  "editable": true,
  "grafana_net": false,
  "schemaVersion": 39,
  "version": 1,
  "timezone": "",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "--grafana--",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Total tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 70
              },
              {
                "color": "yellow",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexusagent_total_tokens",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Total cost (USD)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "$",
          "min": 0,
          "max": 100000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 10000
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexusagent_total_cost_usd",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Token rate (tokens/hour)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(nexusagent_total_tokens[1h]))",
          "legendFormat": "tokens/h",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cost rate (USD/hour)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "$",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(nexusagent_total_cost_usd[1h]))",
          "legendFormat": "usd/h",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cumulative tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nexusagent_total_tokens",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    }
  ],
  "requirements": [
    {
      "type": "grafana",
      "id": ">=9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus"
    }
  ]
}