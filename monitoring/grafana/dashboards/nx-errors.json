{
  "id": null,
  "uid": "nx-errors",
  "title": "NexusAgent · Errors",
  "description": "HTTP error rate, breakdown by status, endpoint and method.",
  "tags": [
    "nexusagent",
    "observability",
    "errors"
  ],
  "editable": true,
  "grafana_net": false,
  "schemaVersion": 39,
  "version": 1,
  "timezone": "",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "--grafana--",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Error rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 5.0001
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "name": "Value"
            },
            "properties": [
              {
                "id": "thresholdsStyle",
                "value": {
                  "mode": "background"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "(sum(rate(nexusagent_http_errors_total[5m])) / clamp_min(sum(rate(nexusagent_http_requests_total[5m])), 1)) * 100",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors / 5m",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "green",
                "value": 0.999
              },
              {
                "color": "red",
                "value": 1.0001
              }
            ]
          },
          "custom": {
            "width": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "name": "Value"
            },
            "properties": [
              {
                "id": "thresholdsStyle",
                "value": {
                  "mode": "background"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(increase(nexusagent_http_errors_total[5m]))",
          "legendFormat": "value",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error rate over time",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum(rate(nexusagent_http_errors_total[5m])) / clamp_min(sum(rate(nexusagent_http_requests_total[5m])), 1)) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Errors by status",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(nexusagent_http_errors_total[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Errors by endpoint",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(nexusagent_http_errors_total[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Errors by method",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "lines",
            "lineWidth": 1,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "axisCenteredZero": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(nexusagent_http_errors_total[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    }
  ],
  "requirements": [
    {
      "type": "grafana",
      "id": ">=9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus"
    }
  ]
}